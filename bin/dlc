#!/usr/bin/env bash
# DLC - Local AI Coding Agent
# 蒂爱嘉(北京)有限公司

set -e

DLC_HOME="${DLC_HOME:-$HOME/.dlc}"
DLC_JAR="$DLC_HOME/dlc.jar"
REPO_URL="https://git.dlchm.cn/sunweilin/coding-agent/raw/branch/main"

# dlc upgrade - pull latest jar via git clone
if [ "${1:-}" = "upgrade" ]; then
    echo "  Upgrading DLC..."
    TEMP_DIR=$(mktemp -d)
    git clone --depth 1 "https://git.dlchm.cn/sunweilin/coding-agent.git" "$TEMP_DIR" -q 2>/dev/null
    if [ -f "$TEMP_DIR/dlc.jar" ]; then
        cp "$TEMP_DIR/dlc.jar" "$DLC_JAR"
        # 同时更新启动脚本自身
        if [ -f "$TEMP_DIR/bin/dlc" ]; then
            cp "$TEMP_DIR/bin/dlc" "$DLC_HOME/bin/dlc"
            chmod +x "$DLC_HOME/bin/dlc"
        fi
        echo "  Done. $(du -h "$DLC_JAR" | cut -f1)"
    else
        echo "  Error: Failed to download. Try: git clone https://git.dlchm.cn/sunweilin/coding-agent.git"
    fi
    rm -rf "$TEMP_DIR"
    exit 0
fi

if [ ! -f "$DLC_JAR" ]; then
    echo "Error: dlc.jar not found at $DLC_JAR"
    echo "Run: curl -fsSL ${REPO_URL}/install.sh | bash"
    exit 1
fi

export DLC_WORKSPACE="${DLC_WORKSPACE:-$(pwd)}"
exec java -jar "$DLC_JAR" "$@"
